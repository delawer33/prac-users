# Postgres container bootstrap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=postgres
POSTGRES_HOST_PORT=5432

# Users API host port mapping
USERS_HOST_PORT=8000

# Users service database DSN
postgres_url=postgresql+asyncpg://postgres:your_password_here@users_postgres:5432/postgres

# Local app runtime
app_host=localhost
app_port=8000
app_reload=true
